                        <input type="text" id="bm-student-search-input" placeholder="Digite o nome..." style="width:200px;">
                        <div id="bm-student-search-results" style="max-height:150px;overflow-y:auto;margin-top:4px;"></div>
                        <input type="hidden" name="bm_subject_id" id="bm-subject-id" value="">
                    </div>
                    <div id="bm-class-select" style="display:none;">
                        <label><strong>Turma</strong></label>
                        <input type="text" name="bm_group" value="" style="width:120px;" placeholder="Ex: 1º Ano">
                    </div>
                </div>
                
                <div id="bm-custom-options" style="display:none;width:100%;margin-top:10px;padding:10px;background:#f9f9f9;border-radius:4px;">
                    <strong>Colunas:</strong>
                    <label style="margin-left:10px;"><input type="checkbox" name="bm_custom_columns[]" value="name" checked=""> Nome</label>
                    <label style="margin-left:10px;"><input type="checkbox" name="bm_custom_columns[]" value="group"> Turma</label>
                    <label style="margin-left:10px;"><input type="checkbox" name="bm_custom_columns[]" value="books_read" checked=""> Livros Lidos</label>
                    <label style="margin-left:10px;"><input type="checkbox" name="bm_custom_columns[]" value="reviews"> Resenhas</label>
                    <label style="margin-left:10px;"><input type="checkbox" name="bm_custom_columns[]" value="videos"> Vídeos</label>
